@model GestãoDeTurmas.Views.Shared.PaginacaoViewModel

@if (Model.TotalPaginas > 1)
{
    <nav aria-label="Navegação de página">
        <ul class="paginacao">
            <li class="item-pagina @(Model.TemPaginaAnterior ? "" : "disabled")">
                <a class="link-pagina"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="@Model.FiltrosComPagina(1)">
                    &lt;&lt;
                </a>
            </li>
            <li class="item-pagina @(Model.TemPaginaAnterior ? "" : "disabled")">
                <a class="link-pagina"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="@Model.FiltrosComPagina(Model.PaginaAtual - 1)">
                    &lt;
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="item-pagina @(i == Model.PaginaAtual ? "active" : "")">
                    <a class="link-pagina"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-all-route-data="@Model.FiltrosComPagina(i)">
                        @i
                    </a>
                </li>
            }
            <li class="item-pagina @(Model.TemProximaPagina ? "" : "disabled")">
                <a class="link-pagina"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="@Model.FiltrosComPagina(Model.PaginaAtual + 1)">
                    &gt;
                </a>
            </li>
            <li class="item-pagina @(Model.TemProximaPagina ? "" : "disabled")">
                <a class="link-pagina"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="@Model.FiltrosComPagina(Model.TotalPaginas)">
                    &gt;&gt;
                </a>
            </li>
        </ul>
    </nav>
}