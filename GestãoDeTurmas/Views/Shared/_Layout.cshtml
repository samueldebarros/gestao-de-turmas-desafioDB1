<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestão de Turmas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestãoDeTurmas.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

    <div class="layout-wrapper">

        <aside class="sidebar">

            <div class="sidebar-logo">
                <a asp-controller="PaginaInicial" asp-action="Index">
                    <span class="sidebar-logo-texto">Gestão de Turma</span>
                </a>
            </div>

            <nav class="sidebar-nav">
                <div class="sidebar-secao">Principal</div>

                <a asp-controller="PaginaInicial" asp-action="Index"
                   class="sidebar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "PaginaInicial" ? "ativo" : "")">
                   <icone nome="Casa" />
                    Início
                </a>

                <div class="sidebar-secao">Cadastros</div>

                <a asp-controller="GerenciarAluno" asp-action="Index"
                   class="sidebar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "GerenciarAluno" ? "ativo" : "")">
                    <icone nome="Alunos" />
                    Alunos
                </a>

                <a asp-controller="GerenciarDocente" asp-action="Index"
                   class="sidebar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "GerenciarDocente" ? "ativo" : "")">
                    <icone nome="Docentes" />
                    Docentes
                </a>

                <a asp-controller="GerenciarDisciplina" asp-action="Index"
                   class="sidebar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "GerenciarDisciplina" ? "ativo" : "")">
                    <icone nome="Disciplinas" />
                    Disciplinas
                </a>

                <a asp-controller="GerenciarTurma" asp-action="Index"
                   class="sidebar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "GerenciarTurma" ? "ativo" : "")">
                    <icone nome="Turmas" />
                    Turmas
                </a>
            </nav>

        </aside>

        <div class="conteudo-principal">

            <header class="conteudo-topo">
                <span class="conteudo-topo-titulo">@(ViewData["Title"] ?? "Gestão de Turmas")</span>
            </header>

            <div class="conteudo-corpo">
                @RenderBody()
            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div class="modal fade" id="modal-confirmacao" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="modal-confirmacao-titulo"></h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="modal-confirmacao-mensagem"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="botao botao-secundario" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="botao botao-perigo" id="modal-confirmacao-btn">Confirmar</button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>