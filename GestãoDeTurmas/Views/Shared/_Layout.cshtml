<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestão de Turmas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestãoDeTurmas.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="PaginaInicial" asp-action="Index">
                    <img src="~/images/logo.png" alt="Gestão de Turmas" height="26" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbar-links" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbar-links">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GerenciarAluno" asp-action="Index">Alunos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GerenciarDocente" asp-action="Index">Docentes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GerenciarDisciplina" asp-action="Index">Disciplinas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GerenciarTurma" asp-action="Index">Turmas</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div class="modal fade" id="modal-confirmacao" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="modal-confirmacao-titulo"></h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="modal-confirmacao-mensagem"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="botao botao-secundario" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="botao botao-perigo" id="modal-confirmacao-btn">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>