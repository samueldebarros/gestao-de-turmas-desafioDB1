@{
}

@if (TempData["MensagemErro"] != null)
{
    <div class="alerta alerta-erro" role="alert">
        <strong>Atenção!</strong> @TempData["MensagemErro"]
        <button class="alerta-fechar" onclick="this.parentElement.remove()">X</button>
    </div>
}

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alerta alerta-sucesso" role="alert">
        <strong>Sucesso!</strong> @TempData["MensagemSucesso"]
        <button class="alerta-fechar" onclick="this.parentElement.remove()">X</button>
    </div>
}