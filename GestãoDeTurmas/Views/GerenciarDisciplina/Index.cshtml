@using Common.Enums
@using Common.Utils
@using GestãoDeTurmas.Views.Shared
@model GestãoDeTurmas.Models.Disciplina.GerenciarDisciplinaViewModel

@{
    @Html.AntiForgeryToken()
}

<div class="card">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Gerenciar Disciplinas</h2>
            <button class="botao botao-primario"
                    onclick="abrirModal('@Url.Action("Adicionar")', 'Nova Disciplina')">
                <icone nome="Adicionar"></icone> Nova Disciplina
            </button>
        </div>

        <partial name="_Alertas" />

        <div class="mb-4">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">

                <input type="text" name="pesquisa" class="form-control flex-grow-1"
                       placeholder="Nome ou Ementa" value="@Model.PesquisaAtual" />

                <select name="ativo" class="form-select flex-shrink-0" style="width: 140px;">
                    <option value="">Status</option>
                    <!option value="true" @(Model.AtivoAtual == true ? "selected" : "")>Ativos</!option>
                    <!option value="false" @(Model.AtivoAtual == false ? "selected" : "")>Inativos</!option>
                </select>

                <button type="submit" class="botao-fantasma flex-shrink-0">
                    <icone nome="Filtrar" /> Filtrar
                </button>

                @if (Model.PesquisaAtual != null || Model.AtivoAtual != null)
                {
                    <a asp-action="Index" class="botao botao-limpar flex-shrink-0" title="Limpar Filtros">
                        <icone nome="Lixeira" />
                    </a>
                }
            </form>
        </div>

        @if (!Model.DisciplinasCadastradas.Any())
        {
            <div class="text-center py-5" style="color: var(--cor-texto-suave);">
                <icone nome="Pesquisar" style="font-size: 2.5rem;"></icone>
                <h4 class="mt-3">Nenhuma disciplina encontrada</h4>
                <p>Tente ajustar seus filtros de pesquisa.</p>
                <a asp-action="Index" class="btn btn-outline-primary mt-2">Limpar Busca</a>
            </div>
        }
        else
        {
            <table class="table-gestao">
                <thead>
                    <tr>
                        <th>
                            @{
                                var rotaNome = new Dictionary<string, string>(Model.FiltrosAtivos);
                                rotaNome["ordenacao"] = "Nome";
                                rotaNome["direcao"] = (Model.Ordenacao == "Nome" && Model.Direcao == DirecaoOrdenacaoEnum.Asc) ? "desc" : "asc";
                            }
                            <a asp-action="Index" asp-all-route-data="rotaNome" style="color: #ffffff;">Nome</a>
                            @if (Model.Ordenacao == "Nome")
                            {
                                <icone nome="@(Model.Direcao == DirecaoOrdenacaoEnum.Asc ? TipoIcone.SetaCima : TipoIcone.SetaBaixo)"></icone>
                            }
                        </th>
                        <th class="text-center">
                            @{
                                var rotaCargaHoraria = new Dictionary<string, string>(Model.FiltrosAtivos);
                                rotaCargaHoraria["ordenacao"] = "CargaHoraria";
                                rotaCargaHoraria["direcao"] = (Model.Ordenacao == "CargaHoraria" && Model.Direcao == DirecaoOrdenacaoEnum.Asc ? "desc" : "asc");
                            }
                            <a asp-action="Index" asp-all-route-data="rotaCargaHoraria" style="color: #ffffff;">Carga Horária</a>
                            @if(Model.Ordenacao == "CargaHoraria")
                            {
                                <icone nome="@(Model.Direcao == DirecaoOrdenacaoEnum.Asc ? TipoIcone.SetaCima : TipoIcone.SetaBaixo)"></icone>
                            }
                        </th>
                        <th>Ementa</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 90px;">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var disciplina in Model.DisciplinasCadastradas)
                    {
                        <tr>
                            <td>@disciplina.Nome</td>
                            <td class="text-center">@disciplina.CargaHoraria h</td>
                            <td>@disciplina.Ementa</td>
                            <td class="text-center">
                                @if (disciplina.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>

                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    @if (disciplina.Ativo)
                                    {
                                        <button type="button" class="botao-acao-icone" title="Editar"
                                                onclick="abrirModal('@Url.Action("Editar", new { id = disciplina.Id })', 'Editar Disciplina')">
                                            <icone nome="Caneta" />
                                        </button>

                                        <button type="button"
                                                class="botao-acao-icone sucesso"
                                                title="Inativar"
                                                onclick="abrirModalConfirmacao('@Url.Action("Inativar", new { id = disciplina.Id })', 'Inativar Disciplina')">
                                            <icone nome="Inativar" />
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="botao-acao-icone sucesso"
                                                title="Reativar"
                                                onclick="abrirModalConfirmacao('@Url.Action("Reativar", new { id = disciplina.Id })', 'Reativar Disciplina')">
                                            <icone nome="Reativar" />
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
            <a class="botao-fantasma" asp-controller="PaginaInicial" asp-action="Index">
                <icone nome="SetaEsquerda" /> Voltar
            </a>

            <small class="text-muted">@Model.InicioPagina-@Model.FimPagina de @Model.TotalResultados</small>

            <partial name="_Paginacao" model="@Model.MontarPaginacao("GerenciarDisciplina", "Index")" />
        </div>

        <partial name="_ModalGenerico" />
    </div>
</div>