@using GestãoDeTurmas.Views.Shared
@model GestãoDeTurmas.Models.Disciplina.GerenciarDisciplinaViewModel
@{
    var inicioPagina = (Model.PaginaAtual - 1) * Model.TamanhoPagina + 1;
    var fimPagina = Math.Min(Model.PaginaAtual * Model.TamanhoPagina, Model.TotalResultados);

    var paginacao = new PaginacaoViewModel
    {
        PaginaAtual = Model.PaginaAtual,
        TotalPaginas = Model.TotalPaginas,
        TemPaginaAnterior = Model.TemPaginaAnterior,
        TemProximaPagina = Model.TemProximaPagina,
        Controller = "GerenciarDisciplina",
        Action = "Index",
        Filtros = PaginacaoViewModel.MontarFiltros(
            ("pesquisa", ViewBag.PesquisaAtual),
            ("ativo", ViewBag.AtivoAtual)
        )
    };
}

<div class="card">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Gerenciar Disciplinas</h2>
            <button class="botao botao-primario"
                    onclick="abrirModal('@Url.Action("Adicionar")', 'Nova Disciplina')">
                <icone nome="Adicionar"></icone> Nova Disciplina
            </button>
        </div>

        <partial name="_Alertas" />

        <div class="mb-4">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">

                <input type="text" name="pesquisa" class="form-control flex-grow-1"
                       placeholder="Nome ou Ementa" value="@ViewBag.PesquisaAtual" />

                <select name="ativo" class="form-select flex-shrink-0" style="width: 140px;">
                    <option value="">Status</option>
                    <!option value="true" @(ViewBag.AtivoAtual == true ? "selected" : "")>Ativos</!option>
                    <!option value="false" @(ViewBag.AtivoAtual == false ? "selected" : "")>Inativos</!option>
                </select>

                <button type="submit" class="botao-fantasma flex-shrink-0">
                    <icone nome="Filtrar" /> Filtrar
                </button>

                @if (ViewBag.PesquisaAtual != null || ViewBag.AtivoAtual != null)
                {
                    <a asp-action="Index" class="botao botao-limpar flex-shrink-0" title="Limpar Filtros">
                        <icone nome="Lixeira" />
                    </a>
                }
            </form>
        </div>

        @if (!Model.DisciplinasCadastradas.Any())
        {
            <div class="text-center py-5" style="color: var(--cor-texto-suave);">
                <icone nome="Pesquisar" style="font-size: 2.5rem;"></icone>
                <h4 class="mt-3">Nenhuma disciplina encontrada</h4>
                <p>Tente ajustar seus filtros de pesquisa.</p>
                <a asp-action="Index" class="btn btn-outline-primary mt-2">Limpar Busca</a>
            </div>
        }
        else
        {
            <table class="table-gestao">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th class="text-center">Carga Horária</th>
                        <th>Ementa</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 90px;">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var disciplina in Model.DisciplinasCadastradas)
                    {
                        <tr>
                            <td>@disciplina.Nome</td>
                            <td class="text-center">@disciplina.CargaHoraria h</td>
                            <td>@disciplina.Ementa</td>
                            <td class="text-center">
                                @if (disciplina.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>

                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    @if (disciplina.Ativo)
                                    {
                                        <button type="button" class="botao-acao-icone" title="Editar"
                                                onclick="abrirModal('@Url.Action("Editar", new { id = disciplina.Id })', 'Editar Disciplina')">
                                            <icone nome="Caneta" />
                                        </button>

                                        <form asp-action="Inativar" asp-route-id="@disciplina.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="pesquisa" value="@ViewBag.PesquisaAtual" />
                                            <input type="hidden" name="ativo" value="@ViewBag.AtivoAtual?.ToString().ToLower()" />
                                            <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                            <button type="button" class="botao-acao-icone" title="Inativar"
                                                    onclick="confirmar('Inativar disciplina', 'Tem certeza que deseja inativar esta disciplina?', () => this.closest('form').submit(), 'botao-perigo')">
                                                <icone nome="Lixeira" />
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reativar" asp-route-id="@disciplina.Id" method="post" class="m-0 w-100 d-flex justify-content-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="pesquisa" value="@ViewBag.PesquisaAtual" />
                                            <input type="hidden" name="ativo" value="@ViewBag.AtivoAtual?.ToString().ToLower()" />
                                            <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                            <button type="button" class="botao-acao-icone sucesso" title="Reativar"
                                                    onclick="confirmar('Reativar disciplina', 'Tem certeza que deseja reativar esta disciplina?', () => this.closest('form').submit(), 'botao-sucesso')">
                                                <icone nome="Check" />
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
            <a class="botao-fantasma" asp-controller="PaginaInicial" asp-action="Index">
                <icone nome="SetaEsquerda" /> Voltar
            </a>

            <small class="text-muted">@inicioPagina-@fimPagina de @Model.TotalResultados</small>

            <partial name="_Paginacao" model="paginacao" />
        </div>

        <partial name="_ModalGenerico" />
    </div>
</div>