@model GestãoDeTurmas.Models.Disciplina.GerenciarDisciplinaViewModel
@{
    var inicioPagina = (Model.PaginaAtual - 1) * Model.TamanhoPagina + 1;
    var fimPagina = Math.Min(Model.PaginaAtual * Model.TamanhoPagina, Model.TotalResultados);
}

<link href="~/css/gerenciarAlunos.css" rel="stylesheet" />

<div class="card">
    <div class="card-body">
        <h1>Gerenciar Disciplinas</h1> <br />

        @if (TempData["MensagemErro"] != null)
        {
            <div class="alerta alerta-erro" role="alert">
                <strong>Atenção!</strong> @TempData["MensagemErro"]
                <button class="alerta-fechar" onclick="this.parentElement.remove()">X</button>
            </div>
        }

        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alerta alerta-sucesso" role="alert">
                <strong>Sucesso!</strong> @TempData["MensagemSucesso"]
                <button class="alerta-fechar" onclick="this.parentElement.remove()">X</button>
            </div>
        }

        <form asp-action="Index" method="get">
            <div class="row align-items-end">

                <div class="col">
                    <label class="form-label">Pesquisar</label>
                    <input type="text" name="pesquisa" class="form-control"
                           placeholder="Nome ou Ementa" value="@ViewBag.PesquisaAtual" />
                </div>

                <div class="col-3">
                    <label class="form-label">Status</label>
                    <select name="ativo" class="form-select">
                        <option value="">Todos</option>
                        <!option value="true" @(ViewBag.AtivoAtual == true ? "selected" : "")>Ativos</!option>
                        <!option value="false" @(ViewBag.AtivoAtual == false ? "selected" : "")>Inativos</!option>
                    </select>
                </div>

                <div class="col-auto">
                    <label class="form-label invisible">.</label>
                    <button type="submit" class="botao botao-primario botao-filtrar"> Filtrar </button>
                </div>
            </div>

            @if (ViewBag.PesquisaAtual != null || ViewBag.SexoAtual != null || ViewBag.AtivoAtual != null)
            {
                <div class="row mb-3">
                    <div class="col-12">
                        <small>Filtros aplicados.</small>
                        <a asp-action="Index" class="text-danger text-decoration-none">Limpar tudo ✖</a>
                    </div>
                </div>
            }
        </form>

        @if (!Model.DisciplinasCadastradas.Any())
        {
            <div class="text-center py-5">
                <h4 class="mt-3">Nenhuma disciplina encontrada</h4>
                <p class="text-muted">Tente ajustar seus filtros de pesquisa.</p>
                <a asp-action="Index" class="btn btn-outline-primary mt-2">Limpar Busca</a>
            </div>
        }
        else
        {
            <table class="table-gestao">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th class="text-center">Carga Horária</th>
                        <th>Ementa</th>
                        <th class="text-center">Ativo</th>
                        <th class="col-acao-tabela"></th>
                        <th class="col-acao-tabela"></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var disciplina in Model.DisciplinasCadastradas)
                    {
                        <tr>
                            <td>@disciplina.Nome</td>
                            <td class="text-center">@disciplina.CargaHoraria h</td>
                            <td>@disciplina.Ementa</td>
                            <td class="text-center">
                                @if (disciplina.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>

                            @if (disciplina.Ativo)
                            {
                                <td><a role="button" class="botao botao-primario botao-acao-tabela" asp-action="Editar" asp-route-id="@disciplina.Id">Editar</a></td>
                                <td>
                                    <form asp-action="Inativar" asp-route-id="@disciplina.Id" method="post">
                                        <input type="hidden" name="pesquisa" value="@ViewBag.PesquisaAtual" />
                                        <input type="hidden" name="ativo" value="@ViewBag.AtivoAtual?.ToString().ToLower()" />
                                        <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                        <button type="submit" class="botao botao-perigo botao-acao-tabela" onclick="return confirm('Tem certeza?')">
                                            Inativar
                                        </button>
                                    </form>
                                </td>
                            }
                            else
                            {
                                <td colspan="2" class="text-center">
                                    <form asp-action="Reativar" asp-route-id="@disciplina.Id" method="post">
                                        <input type="hidden" name="pesquisa" value="@ViewBag.PesquisaAtual" />
                                        <input type="hidden" name="ativo" value="@ViewBag.AtivoAtual?.ToString().ToLower()" />
                                        <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                        <button type="submit" class="botao botao-sucesso botao-acao-tabela w-100" onclick="return confirm('Tem certeza?')">
                                            Reativar
                                        </button>
                                    </form>
                                </td>
                            }

                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex gap-2">
                <a role="button" class="botao botao-primario botao-acao" asp-controller="GerenciarDisciplina" asp-action="Adicionar">Adicionar</a>
                <a class="btn btn-outline-secondary botao-acao" asp-controller="PaginaInicial" asp-action="Index">Voltar</a>
            </div>

            <small class="text-muted">@inicioPagina-@fimPagina de @Model.TotalResultados</small>

            @if (Model.TotalPaginas > 1)
            {
                <nav aria-label="Navegação de página">
                    <ul class="pagination mb-0">

                        <li class="page-item @(Model.TemPaginaAnterior ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pagina="1"
                               asp-route-pesquisa="@ViewBag.PesquisaAtual"
                               asp-route-ativo="@ViewBag.AtivoAtual">
                                &lt&lt
                            </a>
                        </li>

                        <li class="page-item @(Model.TemPaginaAnterior ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pagina="@(Model.PaginaAtual - 1)"
                               asp-route-pesquisa="@ViewBag.PesquisaAtual"
                               asp-route-ativo="@ViewBag.AtivoAtual">
                                &lt
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPaginas; i++)
                        {
                            <li class="page-item @(i == Model.PaginaAtual ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-pagina="@i"
                                   asp-route-pesquisa="@ViewBag.PesquisaAtual"
                                   asp-route-ativo="@ViewBag.AtivoAtual">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.TemProximaPagina ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pagina="@(Model.PaginaAtual + 1)"
                               asp-route-pesquisa="@ViewBag.PesquisaAtual"
                               asp-route-ativo="@ViewBag.AtivoAtual">
                                &gt
                            </a>
                        </li>

                        <li class="page-item @(Model.TemProximaPagina ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pagina="@(Model.TotalPaginas)"
                               asp-route-pesquisa="@ViewBag.PesquisaAtual"
                               asp-route-ativo="@ViewBag.AtivoAtual">
                                &gt&gt
                            </a>
                        </li>

                    </ul>
                </nav>
            }
        </div>
    </div>
</div>