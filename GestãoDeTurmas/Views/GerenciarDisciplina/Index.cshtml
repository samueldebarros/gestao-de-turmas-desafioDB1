@model GestãoDeTurmas.Models.Disciplina.GerenciarDisciplinaViewModel


<link href="~/css/gerenciarAlunos.css" rel="stylesheet" />

<div class="card">
    <div class="card-body">
        <h1>Gerenciar Disciplinas</h1> <br />

        @if (TempData["MensagemErro"] != null)
        {
            <div class="alertaErro">
                @TempData["MensagemErro"]
            </div>
        }

        <form asp-action="Index" method="get">
            <div class="row mb-3 align-items-end">

                <div class="col-4">
                    <label class="form-label">Pesquisar</label>
                    <input type="text" name="pesquisa" class="form-control"
                           placeholder="Nome" value="@ViewBag.PesquisaAtual" />
                </div>

                <div class="col-3">
                    <label class="form-label">Status</label>
                    <select name="ativo" class="form-select">
                        <option value="">Todos</option>
                        <!option value="true" @(ViewBag.AtivoAtual == true ? "selected" : "")>Ativos</!option>
                        <!option value="false" @(ViewBag.AtivoAtual == false ? "selected" : "")>Inativos</!option>
                    </select>
                </div>

                <div class="col-5">
                    <button type="submit" class="btn btn-primary w-100"> Filtrar </button>
                </div>
            </div>

            @if (ViewBag.PesquisaAtual != null || ViewBag.SexoAtual != null || ViewBag.AtivoAtual != null)
            {
                <div class="row mb-3">
                    <div class="col-12">
                        <small>Filtros aplicados.</small>
                        <a asp-action="Index" class="text-danger text-decoration-none">Limpar tudo ✖</a>
                    </div>
                </div>
            }
        </form>


        <table class="text-center">
            <thead>
                <tr class="text-center">
                    <th>Nome</th>
                    <th>Carga Horária</th>
                    <th>Ementa</th>
                    <th>Ativo</th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var disciplina in Model.DisciplinasCadastradas)
                {
                    <tr>
                        <td>@disciplina.Nome</td>
                        <td>@disciplina.CargaHoraria h</td>
                        <td>@disciplina.Ementa</td>
                        <td>
                            @if (disciplina.Ativo)
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inativo</span>
                            }
                        </td>

                        <td><a role="button" class="btn btn-primary w-100" asp-action="Editar" asp-route-id="@disciplina.Id">Editar</a></td>
                        <td>
                            @if (disciplina.Ativo)
                            {
                                <form asp-action="Inativar" asp-route-id="@disciplina.Id" method="post">
                                    <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Tem certeza?')">
                                        Inativar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Reativar" asp-route-id="@disciplina.Id" method="post">
                                    <button type="submit" class="btn btn-success w-100" onclick="return confirm('Tem certeza?')">
                                        Reativar
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex gap-2">
                <a role="button" class="btn btn-primary" asp-controller="GerenciarDisciplina" asp-action="Adicionar">Adicionar</a>
                <a class="btn btn-primary" asp-controller="PaginaInicial" asp-action="Index">Voltar</a>
            </div>
        </div>
    </div>
</div>
