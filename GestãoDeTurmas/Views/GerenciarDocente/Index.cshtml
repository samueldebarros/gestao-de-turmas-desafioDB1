@model GestãoDeTurmas.Models.Docente.GerenciarDocenteViewModel
@{
}

<link href="~/css/gerenciarAlunos.css" rel="stylesheet" />

<div class="card">
	<div class="card-body">
		<h1>Gerenciar docentes</h1> <br />

		@if (TempData["MensagemErro"] != null)
		{
			<div class="alertaErro">
				@TempData["MensagemErro"]
			</div>
		}

		<form asp-action="Index" method="get">
			<div class="row mb-3 align-items-end">

				<div class="col-4">
					<label class="form-label">Pesquisar</label>
					<input type="text" name="pesquisa" class="form-control"
						   placeholder="Nome, CPF ou Especialidade" value="@ViewBag.PesquisaAtual" />
				</div>

				<div class="col-3">
					<label class="form-label">Status</label>
					<select name="ativo" class="form-select">
						<option value="">Todos</option>
						<!option value="true" @(ViewBag.AtivoAtual == true ? "selected" : "")>Ativos</!option>
						<!option value="false" @(ViewBag.AtivoAtual == false ? "selected" : "")>Inativos</!option>
					</select>
				</div>

				<div class="col-5">
					<button type="submit" class="btn btn-primary w-100"> Filtrar </button>
				</div>
			</div>

			@if (ViewBag.PesquisaAtual != null || ViewBag.SexoAtual != null || ViewBag.AtivoAtual != null)
			{
				<div class="row mb-3">
					<div class="col-12">
						<small>Filtros aplicados.</small>
						<a asp-action="Index" class="text-danger text-decoration-none">Limpar tudo ✖</a>
					</div>
				</div>
			}
		</form>


		<table class="text-center">
			<thead>
				<tr class="text-center">
					<th>Nome</th>
					<th>Especialidade</th>
					<th>CPF</th>
					<th>Email</th>
					<th>Data de Nascimento</th>
					<th>Status</th>
					<th></th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				
				@foreach (var docente in Model.DocentesCadastrados)
				{
					<tr>
						<td>@docente.Nome</td>
						<td>@docente.Especialidade</td>
						<td class="text-nowrap">@docente.Cpf</td>
						<td>@(docente.Email ?? "-")</td>
						<td>@docente.DataNascimento.ToString("dd/MM/yyyy")</td>
						<td>
							@if (docente.Ativo)
							{
								<span class="badge bg-success">Ativo</span>
							}
							else
							{
								<span class="badge bg-danger">Inativo</span>
							}
						</td>

						<td><a role="button" class="btn btn-primary w-100" asp-action="Editar" asp-route-id="@docente.Id">Editar</a></td>
						<td>
							@if (docente.Ativo)
							{
								<form asp-action="Inativar" asp-route-id="@docente.Id" method="post">
									<button type="submit" class="btn btn-danger w-100" onclick="return confirm('Tem certeza?')">
										Inativar
									</button>
								</form>
							}
							else
							{
								<form asp-action="Reativar" asp-route-id="@docente.Id" method="post">
									<button type="submit" class="btn btn-success w-100" onclick="return confirm('Tem certeza?')">
										Reativar
									</button>
								</form>
							}
						</td>
					</tr>
				}
				
			</tbody>
		</table>

		<div class="d-flex justify-content-between align-items-center mb-3">
			<a role="button" class="btn btn-primary w-25" asp-controller="GerenciarDocente" asp-action="Adicionar">Adicionar docente</a>
		</div>
	</div>
</div>
