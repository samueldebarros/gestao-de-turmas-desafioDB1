@using GestãoDeTurmas.Views.Shared
@model GestãoDeTurmas.Models.Docente.GerenciarDocenteViewModel
@{
    var inicioPagina = (Model.PaginaAtual - 1) * Model.TamanhoPagina + 1;
    var fimPagina = Math.Min(Model.PaginaAtual * Model.TamanhoPagina, Model.TotalResultados);

    var paginacao = new PaginacaoViewModel
    {
        PaginaAtual = Model.PaginaAtual,
        TotalPaginas = Model.TotalPaginas,
        TemPaginaAnterior = Model.TemPaginaAnterior,
        TemProximaPagina = Model.TemProximaPagina,
        Controller = "GerenciarDocente",
        Action = "Index",
        Filtros = PaginacaoViewModel.MontarFiltros(
        ("pesquisa", Model.PesquisaAtual),
        ("ativo", Model.AtivoAtual)
    )
    };
}

<div class="card">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Gerenciar Docentes</h2>
            <button class="botao botao-primario"
                    onclick="abrirModal('@Url.Action("Adicionar")', 'Novo Docente')">
                <icone nome="Adicionar"></icone> Novo Docente
            </button>
        </div>

        <partial name="_Alertas" />

        <div class="mb-4">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">

                <input type="text" name="pesquisa" class="form-control flex-grow-1"
                       placeholder="Nome, CPF ou Disciplina" value="@Model.PesquisaAtual" />

                <select name="ativo" class="form-select flex-shrink-0" style="width: 140px;">
                    <option value="">Status</option>
                    <!option value="true" @(Model.AtivoAtual == true ? "selected" : "")>Ativos</!option>
                    <!option value="false" @(Model.AtivoAtual == false ? "selected" : "")>Inativos</!option>
                </select>

                <button type="submit" class="botao-fantasma flex-shrink-0">
                    <icone nome="Filtrar" /> Filtrar
                </button>

                @if (Model.PesquisaAtual != null || Model.AtivoAtual != null)
                {
                    <a asp-action="Index" class="botao botao-limpar flex-shrink-0" title="Limpar Filtros">
                        <icone nome="Lixeira" />
                    </a>
                }
            </form>
        </div>

        @if (!Model.DocentesCadastrados.Any())
        {
            <div class="text-center py-5" style="color: var(--cor-texto-suave);">
                <icone nome="Pesquisar" style="font-size: 2.5rem;"></icone>
                <h4 class="mt-3">Nenhum docente encontrado</h4>
                <p>Tente ajustar seus filtros de pesquisa.</p>
                <a asp-action="Index" class="btn btn-outline-primary mt-2">Limpar Busca</a>
            </div>
        }
        else
        {
            <table class="table-gestao">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Disciplina</th>
                        <th>CPF</th>
                        <th>Email</th>
                        <th>Data de Nascimento</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 90px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var docente in Model.DocentesCadastrados)
                    {
                        <tr>
                            <td>@docente.Nome</td>
                            <td>@(docente.NomeDisciplina ?? "Não vinculada")</td>
                            <td class="text-nowrap">@docente.CpfFormatado</td>
                            <td>@(docente.Email ?? "-")</td>
                            <td>@docente.DataNascimento.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                @if (docente.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>

                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    @if (docente.Ativo)
                                    {
                                        <button type="button" class="botao-acao-icone" title="Editar"
                                                onclick="abrirModal('@Url.Action("Editar", new { id = docente.Id })', 'Editar Docente')">
                                            <icone nome="Caneta" />
                                        </button>

                                        <form asp-action="Inativar" asp-route-id="@docente.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                            <input type="hidden" name="pesquisa" value="@Model.PesquisaAtual" />
                                            <input type="hidden" name="ativo" value="@Model.AtivoAtual?.ToString().ToLower()" />
                                            <button type="button" class="botao-acao-icone" title="Inativar"
                                                    onclick="confirmar('Inativar docente', 'Tem certeza que deseja inativar este docente?', () => this.closest('form').submit(), 'botao-perigo')">
                                                <icone nome="Inativar" />
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reativar" asp-route-id="@docente.Id" method="post" class="m-0 w-100 d-flex justify-content-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                            <input type="hidden" name="pesquisa" value="@Model.PesquisaAtual" />
                                            <input type="hidden" name="ativo" value="@Model.AtivoAtual?.ToString().ToLower()" />
                                            <button type="button" class="botao-acao-icone sucesso" title="Reativar"
                                                    onclick="confirmar('Reativar docente', 'Tem certeza que deseja reativar este docente?', () => this.closest('form').submit(), 'botao-sucesso')">
                                                <icone nome="Reativar" />
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
            <a class="botao-fantasma" asp-controller="PaginaInicial" asp-action="Index">
                <icone nome="SetaEsquerda" /> Voltar
            </a>

            <small class="text-muted">@inicioPagina-@fimPagina de @Model.TotalResultados</small>

            <partial name="_Paginacao" model="paginacao" />
        </div>

        <partial name="_ModalGenerico" />
    </div>
</div>