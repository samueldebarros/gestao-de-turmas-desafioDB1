@model GestãoDeTurmas.Models.Docente.DocenteEditarViewModel
@{
}

<form method="post" class="form-container">
    <h1>Editar Docente</h1>

    <div asp-validation-summary="ModelOnly" class="alerta alerta-erro" role="alert"></div>

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label for="nome">Nome</label>
        <input type="text" asp-for="Nome" class="form-control" placeholder="Novo nome">
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="email">Email</label>
        <input type="text" asp-for="Email" class="form-control" placeholder="Novo Email">
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="disciplina">Disciplina</label>
        <select asp-for="DisciplinaId" asp-items="ViewBag.Disciplinas" class="form-select">
            <option value="">Nenhuma</option>
        </select>
    </div>
    <div class="form-group">
        <label for="dataNascimento">Data de Nascimento</label>
        <input type="date" asp-for="DataNascimento" class="form-control">
        <span asp-validation-for="DataNascimento" class="text-danger"></span>
    </div>

    <br />
    <div class="d-flex gap-2">
        <button type="submit" class="botao botao-primario botao-acao">Editar</button>
        <a class="btn btn-outline-secondary botao-acao" asp-controller="GerenciarDocente" asp-action="Index">Voltar</a>
    </div>
</form>

