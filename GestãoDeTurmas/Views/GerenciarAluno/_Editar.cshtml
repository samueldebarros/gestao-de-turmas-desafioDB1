@using GestãoDeTurmas.Models.Aluno
@model AlunoEditarViewModel
@{
}
<form method="post" asp-action="Editar" asp-controller="GerenciarAluno">
    <div asp-validation-summary="ModelOnly" class="alerta alerta-erro" role="alert"></div>

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label for="nome">Nome</label>
        <input type="text" asp-for="Nome" class="form-control" placeholder="Novo nome">
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="email">Email</label>
        <input type="text" asp-for="Email" class="form-control" placeholder="Novo Email">
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="dataNascimento">Data de Nascimento</label>
        <input type="date" asp-for="DataNascimento" class="form-control">
        <span asp-validation-for="DataNascimento" class="text-danger"></span>
    </div>

    <h6>Sexo</h6>

    <div class="form-check">
        <input class="form-check-input" type="radio" asp-for="Sexo" value="Masculino" id="masculino">
        <label class="form-check-label" for="masculino">
            Masculino
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="radio" asp-for="Sexo" value="Feminino" id="feminino">
        <label class="form-check-label" for="feminino">
            Feminino
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="radio" asp-for="Sexo" value="Outro" id="outro">
        <label class="form-check-label" for="outro">
            Outro
        </label>
    </div>

    <br />
    <div class="d-flex gap-2">
        <button type="submit" class="botao botao-primario botao-acao">Editar</button>
    </div>
</form>