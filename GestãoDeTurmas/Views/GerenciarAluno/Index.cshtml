@using Common.Enums
@using GestãoDeTurmas.Views.Shared
@model GestãoDeTurmas.Models.Aluno.GerenciarAlunoViewModel

@{
    var inicioPagina = (Model.PaginaAtual - 1) * Model.TamanhoPagina + 1;
    var fimPagina = Math.Min(Model.PaginaAtual * Model.TamanhoPagina, Model.TotalResultados);

    var paginacao = new PaginacaoViewModel
    {
        PaginaAtual = Model.PaginaAtual,
        TotalPaginas = Model.TotalPaginas,
        TemPaginaAnterior = Model.TemPaginaAnterior,
        TemProximaPagina = Model.TemProximaPagina,
        Controller = "GerenciarAluno",
        Action = "Index",
        Filtros = PaginacaoViewModel.MontarFiltros(
        ("pesquisa", Model.PesquisaAtual),
        ("sexo", Model.SexoAtual),
        ("ativo", Model.AtivoAtual)
    )
    };
}

<div class="card">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Gerenciar Alunos</h2>
            <button class="botao botao-primario"
                    onclick="abrirModal('@Url.Action("Adicionar")', 'Adicionar Aluno')">
                <icone nome="Adicionar"></icone> Novo Aluno
            </button>
        </div>

        <partial name="_Alertas" />

        <div class="mb-4">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">

                <input type="text" name="pesquisa" class="form-control flex-grow-1"
                       placeholder="Nome, CPF ou Matricula" value="@Model.PesquisaAtual" />

                <select name="sexo" class="form-select flex-shrink-0" style="width: 140px;">
                    <option value="">Sexo</option>
                    <!option value="1" @(Model.SexoAtual == SexoEnum.Masculino ? "selected" : "")>Masculino</!option>
                    <!option value="2" @(Model.SexoAtual == SexoEnum.Feminino ? "selected" : "")>Feminino</!option>
                    <!option value="3" @(Model.SexoAtual == SexoEnum.Outro ? "selected" : "")>Outro</!option>
                </select>

                <select name="ativo" class="form-select flex-shrink-0" style="width: 140px;">
                    <option value="">Status</option>
                    <!option value="true" @(Model.AtivoAtual == true ? "selected" : "")>Ativos</!option>
                    <!option value="false" @(Model.AtivoAtual == false ? "selected" : "")>Inativos</!option>
                </select>

                <button type="submit" class="botao-fantasma flex-shrink-0">
                    <icone nome="Filtrar" /> Filtrar
                </button>

                @if (Model.PesquisaAtual != null || Model.SexoAtual != null || Model.AtivoAtual != null)
                {
                    <a asp-action="Index" class="botao botao-limpar flex-shrink-0" title="Limpar Filtros">
                        <icone nome="Lixeira" />
                    </a>
                }
            </form>
        </div>

        @if (!Model.AlunosCadastrados.Any())
        {
            <div class="text-center py-5" style="color: var(--cor-texto-suave);">
                <icone nome="Pesquisar" style="font-size: 2.5rem;"></icone>
                <h4 class="mt-3">Nenhum aluno encontrado</h4>
                <p>Tente ajustar seus filtros de pesquisa.</p>
            </div>
        }
        else
        {
            <table class="table-gestao">
                <thead>
                    <tr>
                        <th>Matricula</th>
                        <th>
                            <a asp-action="Index" asp->
                                Nome
                            </a>
                        </th>
                        <th>CPF</th>
                        <th>Email</th>
                        <th>Nascimento</th>
                        <th>Sexo</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 90px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var aluno in Model.AlunosCadastrados)
                    {
                        <tr>
                            <td><strong>@aluno.Matricula</strong></td>
                            <td>@aluno.NomeExibicao</td>
                            <td class="text-nowrap">@aluno.CpfFormatado</td>
                            <td>@(aluno.Email ?? "-")</td>
                            <td>@aluno.DataNascimento.ToString("dd/MM/yyyy")</td>
                            <td>@aluno.Sexo</td>
                            <td class="text-center">
                                @if (aluno.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>

                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    @if (aluno.Ativo)
                                    {
                                        <button type="button" class="botao-acao-icone" title="Editar"
                                                onclick="abrirModal('@Url.Action("Editar", new { id = aluno.Id })', 'Editar Aluno')">
                                            <icone nome="Caneta" />
                                        </button>

                                        <form asp-action="Inativar" asp-route-id="@aluno.Id" method="post" class="m-0">
                                            <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                            <button type="button" class="botao-acao-icone" title="Inativar"
                                                    onclick="confirmar('Inativar aluno', 'Tem certeza?', () => this.closest('form').submit(), 'botao-perigo')">
                                                <icone nome="Inativar" />
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Reativar" asp-route-id="@aluno.Id" method="post" class="m-0 w-100 d-flex justify-content-center">
                                            <input type="hidden" name="pagina" value="@Model.PaginaAtual" />
                                            <button type="button" class="botao-acao-icone sucesso" title="Reativar"
                                                    onclick="confirmar('Reativar aluno', 'Tem certeza?', () => this.closest('form').submit(), 'botao-sucesso')">
                                                <icone nome="Reativar" />
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
            <a class="botao-fantasma" asp-controller="PaginaInicial" asp-action="Index">
                <icone nome="SetaEsquerda" /> Voltar
            </a>
            <small class="text-muted">@inicioPagina-@fimPagina de @Model.TotalResultados</small>
            <partial name="_Paginacao" model="paginacao" />
        </div>
    </div>
</div>

<partial name="_ModalGenerico" />
