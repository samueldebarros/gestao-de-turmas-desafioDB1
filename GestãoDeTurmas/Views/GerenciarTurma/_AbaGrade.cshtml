@model GestãoDeTurmas.Models.Turma.TurmaDetalhesViewModel

<div class="card mb-4 shadow-sm">
    <div class="card-body align-content-center">
        <h6 class="card-title mb-3 text-primary">
            <icone nome="Adicionar"> Vincular Disciplina e Docente</icone>
        </h6>

        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label for="select-disciplina" class="form-label mb-1 fw-bold" style="font-size: 14px;">Disciplina</label>

                <select id="select-disciplina" class="form-select" asp-items="Model.DisciplinasDisponiveis">
                    <option value="">Selecione a disciplina...</option>
                </select>
            </div>

            <div class="col-md-5">
                <label for="select-docente" class="form-label mb-1 fw-bold">Docentes</label>

                <select id="select-docente" class="form-select" disabled>
                    <option value="">Selecione a disciplina primeiro...</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="button" class="botao botao-primario w-100" id="btn-vincular">
                    Vincular
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h6 class="card-title mb-3 text-secondary">Vínculos Atuais da Turma</h6>

        <div class="table-responsive mt-3">
            <table class="table-gestao w-100" id="tabela-grade">
                <thead>
                    <tr>
                        <th style="width: 40%;">Disciplina</th>
                        <th>Docente Responsável</th>
                        <th class="text-end" style="width: 100px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Grade.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <icone nome="Aviso" /> Nenhuma disciplina vinculada ainda.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Grade)
                    {
                        <tr>
                            <td class="fw-bold">@item.Disciplina</td>
                            <td>@item.Docente</td>
                            <td class="text-end">
                                <button type="button"
                                        class="botao-icone text-danger btn-remover-grade"
                                        data-disciplina-id="@item.DisciplinaId"
                                        title="Remover Vínculo">
                                    <icone nome="Lixeira" />
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>