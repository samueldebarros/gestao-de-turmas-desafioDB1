@model GestãoDeTurmas.Models.Turma.GerenciarTurmaViewModel;
<div>
    <div class="d-flex justify-content-between pb-4">
        <h4>Gerenciar Turmas</h4>
        <button type="button" class="botao botao-primario" onclick="abrirModal('@Url.Action("Adicionar")', 'Adicionar Turma')">Adicionar</button>
    </div>

    <partial name="_Alertas"></partial>

    <div class="cards-turmas flex-md-column">
        @foreach(var turma in Model.Turmas)
        {
            <partial name="_CardTurma" model="turma" />
        }

    </div>
</div>

<partial name="_ModalGenerico" />