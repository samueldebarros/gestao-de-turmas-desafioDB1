@model GestãoDeTurmas.Models.Turma.GerenciarTurmaViewModel;
<div class="card">
    <div class="d-flex justify-content-between card-header">
        <h4>Gerenciar Turmas</h4>
        <button type="button" class="botao botao-primario">Adicionar</button>
    </div>
    <div class="card-body d-flex gap-3">
        @foreach(var turma in Model.Turmas)
        {
            <partial name="_CardTurma" model="turma" />
        }

    </div>
</div>