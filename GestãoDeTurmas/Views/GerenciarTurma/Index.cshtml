@using Common.Enums
@model GestãoDeTurmas.Models.Turma.GerenciarTurmaViewModel

@{
    ViewData["Title"] = "Turmas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestão de Turmas</h2>

    <button class="botao botao-primario"
            onclick="abrirModal('@Url.Action("Adicionar")', 'Nova Turma')">
        <i class="bi bi-plus-lg"></i> Nova Turma
    </button>
</div>

<div class="mb-4">
    <form method="get" class="d-flex gap-2 align-items-center">
        <input type="text" name="pesquisa" value="@Model.Pesquisa"
               placeholder="Pesquisar..." class="form-control flex-grow-1" />

        <select name="ativo" class="form-select" style="width: 160px; flex-shrink: 0;">
            <option value="">Todos os Status</option>
            <option value="true" selected="@(Model.Ativo == true)">Ativas</option>
            <option value="false" selected="@(Model.Ativo == false)">Inativas</option>
        </select>

        <select name="ordenacao" class="form-select" asp-for="Ordenacao"
                asp-items="Html.GetEnumSelectList<OrdenacaoTurmaEnum>()"
                style="width: 200px; flex-shrink: 0;">
            <option value="">Ordenar por (Padrão)</option>
        </select>

        <button type="submit" class="botao botao-secundario" style="flex-shrink: 0;">
            <icone nome="Pesquisar" /> Filtrar
        </button>

        @if (!string.IsNullOrEmpty(Model.Pesquisa) || Model.Ativo.HasValue || Model.Ordenacao.HasValue)
        {
            <a asp-action="Index" class="botao botao-limpar" style="flex-shrink: 0;">Limpar</a>
        }
    </form>
</div>

@if (!Model.TurmasCadastradas.Any())
{
    <div class="text-center py-5" style="color: var(--cor-texto-suave);">
        <icone nome="Pesquisar" style="font-size: 2.5rem;"></icone>
        <p class="mt-2">Nenhuma turma encontrada no sistema.</p>
    </div>
}
else
{
    <div class="cards-turmas">
        @foreach (var turma in Model.TurmasCadastradas)
        {
            <partial name="_CardTurma" model="turma" />
        }
    </div>
}

<partial name="_ModalGenerico" />